{
  "name": "nutshell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate --schema=src/server/db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/server/db/schema.prisma",
    "db:push": "prisma db push --schema=src/server/db/schema.prisma",
    "db:seed": "npx tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright": "playwright test",
    "postinstall": "patch-package && prisma generate --schema=src/server/db/schema.prisma"
  },
  "prisma": {
    "schema": "src/server/db/schema.prisma",
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@huggingface/transformers": "^4.2.0",
    "@likecoin/epub-ts": "0.6.3",
    "@prisma/client": "5.22.0",
    "@shadcn/react": "^0.1.0",
    "@tanstack/react-query": "5.100.9",
    "@teispace/next-themes": "^0.4.2",
    "better-auth": "1.6.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "franc": "6.2.0",
    "gpt-tokenizer": "^3.4.0",
    "gsap": "^3.15.0",
    "jszip": "3.10.1",
    "kokoro-js": "^1.2.1",
    "lenis": "^1.3.23",
    "lucide-react": "1.14.0",
    "next": "16.2.5",
    "onnxruntime-web": "^1.27.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/eslint": "9",
    "@types/node": "22",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "happy-dom": "^20.10.6",
    "patch-package": "^8.0.0",
    "prisma": "5.22.0",
    "tailwindcss": "4.2.4",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
