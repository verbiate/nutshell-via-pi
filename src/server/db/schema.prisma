generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// UserRole: regular, pro, admin
// Stored as String in SQLite since SQLite lacks native enum support
// Application-level validation enforces valid values

model User {
  id            String          @id
  email         String          @unique
  name          String?
  image         String?
  role              String          @default("regular")
  preferredLanguage String        @default("en")
  emailVerified     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  sessions      Session[]
  accounts      Account[]
  bookAccesses  UserBookAccess[]
  uploadedBooks EpubFile[]      @relation("UploadedBooks")
  auditLogs     AuditLog[]
  positions     UserBookPosition[]
  bookmarks      Bookmark[]
  highlights     Highlight[]
  explainerRequests ExplainerRequest[]
}

model Explainer {
  id            String   @id @default(cuid())
  contentHash   String
  language      String   @default("en")
  contentType   String
  tier          String   @default("regular")
  content       String
  modelId       String
  promptVersion Int
  tokenCount    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([contentHash, language, contentType, tier])
  @@index([contentHash])
  @@index([createdAt])

  requests ExplainerRequest[]
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EpubFile {
  id           String   @id @default(cuid())
  md5          String   @unique
  title        String
  author       String?
  language     String   @default("und")
  coverPath    String?
  epubPath     String
  txtPath      String
  tocJson      String?
  fileSize     Int
  totalParagraphs Int?
  uploadedById String?
  uploadedBy   User?    @relation("UploadedBooks", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userAccesses UserBookAccess[]
  positions     UserBookPosition[]
  bookmarks     Bookmark[]
  highlights    Highlight[]
  explainerRequests ExplainerRequest[]
}

model UserBookAccess {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
}

model PromptTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model UserBookPosition {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  paragraphIndex Int
  charOffset     Int
  cfi            String?
  tocSectionId   String?
  percentage     Int?
  updatedAt      DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  cfi            String
  paragraphIndex Int
  charOffset     Int
  pageNumber     Int?
  sectionHref    String?
  note           String?
  createdAt      DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, cfi])
  @@index([userId])
  @@index([bookId])
}

model Highlight {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  cfi            String
  paragraphIndex Int
  charOffsetStart Int
  charOffsetEnd   Int
  selectedText   String
  color          String
  sectionHref    String?
  pageNumber     Int?
  note           String?
  createdAt      DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, cfi])
  @@index([userId])
  @@index([bookId])
}

model ExplainerRequest {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  explainerId String
  passageCfi  String?
  passageText String?
  sectionHref String?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      EpubFile  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  explainer Explainer @relation(fields: [explainerId], references: [id], onDelete: Cascade)

  @@index([userId, bookId])
  @@index([createdAt])
}

model TtsAudio {
  id          String   @id @default(cuid())
  contentHash String
  language    String
  voiceId     String
  model       String
  provider    String
  storagePath String
  fileSize    Int?
  duration    Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentHash, language, voiceId, model])
  @@index([contentHash])
}

model TtsProviderConfig {
  id        String   @id @default(cuid())
  provider  String
  userType  String
  apiKey    String?
  model     String?
  voiceId   String?
  updatedAt DateTime @updatedAt

  @@unique([provider, userType])
}

model OpenRouterConfig {
  id        String   @id @default(cuid())
  userType  String   @unique
  apiKey    String?
  model     String?
  updatedAt DateTime @updatedAt
}
