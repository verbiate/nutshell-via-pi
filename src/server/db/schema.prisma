generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// UserRole: regular, pro, admin
// Stored as String in SQLite since SQLite lacks native enum support
// Application-level validation enforces valid values

model User {
  id            String          @id
  email         String          @unique
  name          String?
  image         String?
  role              String          @default("regular")
  preferredLanguage String        @default("en")
  emailVerified     Boolean         @default(false)
  playlistAutoAdvance Boolean     @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  sessions      Session[]
  accounts      Account[]
  bookAccesses  UserBookAccess[]
  uploadedBooks EpubFile[]      @relation("UploadedBooks")
  auditLogs     AuditLog[]
  positions     UserBookPosition[]
  bookmarks      Bookmark[]
  highlights     Highlight[]
  explainerRequests ExplainerRequest[]
  explainerThreads  ExplainerThread[]
  playlistItems     PlaylistItem[]
}

model PlaylistItem {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId        String
  sectionHref   String
  sectionLabel  String
  position      Int
  status        String   @default("upcoming")
  bookTitle     String?
  bookAuthor    String?
  bookCoverPath String?
  bookLanguage  String   @default("und")
  addedAt       DateTime @default(now())
  playedAt      DateTime?

  @@unique([userId, position])
  @@index([userId])
  @@index([userId, status])
}

model Explainer {
  id            String   @id @default(cuid())
  contentHash   String
  language      String   @default("en")
  contentType   String
  tier          String   @default("regular")
  content       String
  modelId       String
  promptVersion Int
  // ponytail: version axis turns the cache into a versioned explainer. A
  // re-reroll creates a NEW row (same contentHash/lang/type/tier, version+1)
  // rather than overwriting; discussions pin a specific version via their
  // explainerId, so existing readers keep the version they first saw while new
  // readers get the latest. Lookup = max(version) for the 4-axis key.
  version       Int      @default(1)
  tokenCount    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([contentHash, language, contentType, tier, version])
  @@index([contentHash])
  @@index([createdAt])

  requests ExplainerRequest[]
  threads  ExplainerThread[]
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EpubFile {
  id           String   @id @default(cuid())
  md5          String   @unique
  title        String
  author       String?
  language     String   @default("und")
  coverPath    String?
  epubPath     String
  txtPath      String
  txtTokens    Int?
  tocJson      String?
  fileSize     Int
  totalParagraphs Int?
  uploadedById String?
  uploadedBy   User?    @relation("UploadedBooks", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userAccesses UserBookAccess[]
  positions     UserBookPosition[]
  bookmarks     Bookmark[]
  highlights    Highlight[]
  explainerRequests ExplainerRequest[]
  explainerThreads  ExplainerThread[]
  bookMetadata     BookMetadata?
}

// ponytail: LLM-extracted metadata; canonical display source. EpubFile keeps
// the OPF-derived originals so admins can revert any field. 1:1 with EpubFile.
// Null fields (subtitle/authorGender/isNarrative) on an existing row mean the
// LLM ran but couldn't determine that value; no row at all means never extracted.
model BookMetadata {
  id            String   @id @default(cuid())
  bookId        String   @unique
  title         String
  subtitle      String?
  description   String?
  author        String?
  authorGender  String?  // null = LLM couldn't tell / undeclared; otherwise free-form ("male"/"female"/"nonbinary"/self-description)
  isNarrative   Boolean? // null = LLM couldn't tell
  language      String?
  promptVersion Int
  model         String?
  extractedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model UserBookAccess {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
}

model PromptTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  content   String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model UserBookPosition {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  paragraphIndex Int
  charOffset     Int
  cfi            String?
  tocSectionId   String?
  percentage     Int?
  // ponytail: leading ~60 chars of the last TTS chunk spoken. Lets a book
  // reopened after off-reader playback re-locate the exact chunk's page even
  // when no live CFI was captured (audio kept playing on the bookshelf).
  // Null for manual-only reading or section-level cloud TTS.
  ttsChunkAnchor String?
  updatedAt      DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model Bookmark {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  cfi            String
  paragraphIndex Int
  charOffset     Int
  pageNumber     Int?
  sectionHref    String?
  note           String?
  createdAt      DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, cfi])
  @@index([userId])
  @@index([bookId])
}

model Highlight {
  id             String   @id @default(cuid())
  userId         String
  bookId         String
  cfi            String
  paragraphIndex Int
  charOffsetStart Int
  charOffsetEnd   Int
  selectedText   String
  color          String
  sectionHref    String?
  pageNumber     Int?
  note           String?
  createdAt      DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book EpubFile @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId, cfi])
  @@index([userId])
  @@index([bookId])
}

model ExplainerRequest {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  explainerId String
  passageCfi  String?
  passageText String?
  sectionHref String?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      EpubFile  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  explainer Explainer @relation(fields: [explainerId], references: [id], onDelete: Cascade)

  @@index([userId, bookId])
  @@index([createdAt])
}

model TtsAudio {
  id          String   @id @default(cuid())
  contentHash String
  language    String
  voiceId     String
  model       String
  provider    String
  storagePath String
  fileSize    Int?
  duration    Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contentHash, language, voiceId, model])
  @@index([contentHash])
}

model TtsProviderConfig {
  id        String   @id @default(cuid())
  provider  String
  userType  String
  apiKey    String?
  model     String?
  voiceId   String?
  updatedAt DateTime @updatedAt

  @@unique([provider, userType])
}

// ponytail: per-user monthly quota counter for cloud TTS generations.
// One /api/tts/generate call = 1 increment. periodKey is "YYYY-MM" so the
// counter rolls over automatically each calendar month without a cron job.
model TtsUsage {
  id          String   @id @default(cuid())
  userId      String
  periodKey   String   // "YYYY-MM"
  generations Int      @default(0)
  lastResetAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, periodKey])
  @@index([userId])
}

model OpenRouterConfig {
  id                String   @id @default(cuid())
  userType          String   @unique
  apiKey            String?
  model             String?
  maxContextTokens  Int?
  updatedAt         DateTime @updatedAt
}

// ponytail: KV table for global admin-tunable settings (e.g. globalSystemPrompt).
// Add new keys by calling setSetting("<key>", value) — no schema change needed.
model AppSetting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}

// ponytail: per-user multi-turn discussion threads. The initial response lives
// in the cached `Explainer` row (globally shared, versioned); only follow-up
// turns are stored as `ExplainerMessage`. Uniqueness is on the version-
// independent cache key (contentHash + language + tier) so re-asking the same
// context reopens the existing discussion even after a re-reroll creates a new
// explainer version. `explainerId` pins the exact version this discussion shows;
// `initialCacheHit` records whether the first response was a cache hit (admin UX).
model ExplainerThread {
  id              String   @id @default(cuid())
  userId          String
  bookId          String
  // ponytail: nullable — a "New discussion" starts blank (no explainer seed);
  // the thread is created on the user's first message with the book as context.
  // "Ask about this" flows still pin a versioned explainer here.
  explainerId     String?
  contentHash     String?  // version-independent cache key (nullable for legacy rows pre-backfill + blank discussions)
  type            String   // "passage" | "section" | "book"
  passageCfi      String?
  passageText     String?  // full passage text — re-sent as context on follow-ups
  sectionHref     String?
  language        String
  tier            String
  initialCacheHit Boolean? // admin UX: was the first response served from cache?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  book         EpubFile   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  explainer    Explainer? @relation(fields: [explainerId], references: [id], onDelete: Cascade)
  messages     ExplainerMessage[]

  @@unique([userId, contentHash, language, tier])
  @@index([userId, bookId])
}

model ExplainerMessage {
  id         String   @id @default(cuid())
  threadId   String
  role       String   // "user" | "assistant"
  content    String
  modelId    String?
  createdAt  DateTime @default(now())

  thread     ExplainerThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ponytail: admin-visible error log. Populated by explainer pipeline failures
// (size, missing key, OpenRouter errors) and upload-time blocks. Generic shape
// so future failure sources can record here without schema change.
model SystemError {
  id         String   @id @default(cuid())
  category   String   // "explainer_too_large" | "missing_api_key" | "openrouter_error" | "upload_blocked" | ...
  message    String
  userId     String?
  bookId     String?
  threadId   String?
  context    String?  // JSON string: { tier, model, tokenCount, limit, ... }
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([category, resolved])
}
